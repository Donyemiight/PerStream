# PerStream Backend Configuration
# Copy this file to .env and fill in values.
#
# Two modes of operation:
#   - MOCK: in-memory ledger, no chain, no keys. Great for demos and tests.
#   - LIVE: real USDC on Arc testnet via Circle Gateway (Nanopayments).
#
# See docs/LIVE_DEPLOY.md for full live-mode setup instructions.

# ───────────────────────────────────────────────
# Server
# ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=

# ───────────────────────────────────────────────
# Modes
# ───────────────────────────────────────────────
# Mode of operation: 'mock' or 'live'
# - mock: simulates Nanopayments + Arc settlement in-memory (no keys needed, perfect for demo)
# - live: uses real Circle Nanopayments + Arc testnet via @circle-fin/x402-batching
PAYMENTS_MODE=mock

# ───────────────────────────────────────────────
# Arc + Circle Gateway (only needed when PAYMENTS_MODE=live)
# ───────────────────────────────────────────────
# Arc testnet RPC (use the default or your private endpoint)
ARC_RPC_URL=https://rpc.testnet.arc.io

# Chain ID is auto-detected (5042002 for Arc Testnet)
# Contract addresses below are from @circle-fin/x402-batching (verified):
#   USDC:           0x3600000000000000000000000000000000000000
#   GatewayWallet:  0x0077777d7EBA4688BDeF3E311b846F25870A19B9
#   GatewayMinter:  0x0022222ABE238Cc2C7Bb1f21003F0a260052475B
# No need to set these — the SDK picks them up automatically.

# Backend's settlement private key (KEEP SECRET — used to sign EIP-3009 authorizations
# on behalf of listeners when they hit /api/listen/start)
SETTLEMENT_PRIVATE_KEY=0xe83e1f6a93214d005c18fbacd0fe8e94ff1fcb625ce38613869c6cd9c13eedb8

# Testnet USDC faucet: https://faucet.circle.com

# ───────────────────────────────────────────────
# Circle (only needed when PAYMENTS_MODE=live)
# ───────────────────────────────────────────────
# Optional: Circle API key for advanced operations (transfer search, etc.)
# Not required for basic pay/deposit/withdraw via the SDK.
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=

# ───────────────────────────────────────────────
# Storage
# ───────────────────────────────────────────────
# Local SQLite file (auto-created)
DB_PATH=./data/perstream.db

# Audio upload directory (auto-created)
AUDIO_DIR=./data/audio

# Max audio upload size in bytes (default 50MB)
MAX_AUDIO_BYTES=52428800

# Live mode for demo (set externally for judges to verify on Arcscan)
# To activate: visit https://faucet.circle.com, select "Arc Testnet",
# send 20 USDC to the SELLER_ADDRESS printed by scripts/live-smoke.js,
# then set PAYMENTS_MODE=live and restart the backend.
