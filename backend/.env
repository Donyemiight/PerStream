# PerStream Backend Configuration
# Copy this file to .env and fill in values.

# ───────────────────────────────────────────────
# Server
# ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:3000

# ───────────────────────────────────────────────
# Modes
# ───────────────────────────────────────────────
# Mode of operation: 'mock' or 'live'
# - mock: simulates Nanopayments + Arc settlement in-memory (no keys needed, perfect for demo)
# - live: uses real Circle Nanopayments + Arc testnet
PAYMENTS_MODE=mock

# ───────────────────────────────────────────────
# Arc (only needed when PAYMENTS_MODE=live)
# ───────────────────────────────────────────────
# Arc testnet RPC (from https://docs.arc.io)
ARC_RPC_URL=https://rpc.testnet.arc.io
ARC_CHAIN_ID=1244

# The deployed PerStreamPaymaster contract address
PERSTREAM_PAYMASTER_ADDRESS=0x0000000000000000000000000000000000000000

# Testnet USDC address on Arc (fill when known)
USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Backend's settlement private key (KEEP SECRET — for tick() calls on behalf of listeners)
SETTLEMENT_PRIVATE_KEY=

# ───────────────────────────────────────────────
# Circle (only needed when PAYMENTS_MODE=live)
# ───────────────────────────────────────────────
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=

# ───────────────────────────────────────────────
# Storage
# ───────────────────────────────────────────────
# Local SQLite file (auto-created)
DB_PATH=./data/perstream.db

# Audio upload directory (auto-created)
AUDIO_DIR=./data/audio

# Max audio upload size in bytes (default 50MB)
MAX_AUDIO_BYTES=52428800